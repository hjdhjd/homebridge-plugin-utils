/* Copyright(C) 2017-2026, HJD (https://github.com/hjdhjd). All rights reserved.
 *
 * tsconfig.build.json: TypeScript project used by `tsc` to emit the published `dist/` output. Narrowly scoped to `src/` so the emit graph stays free of build scripts,
 * web UI assets, and root-level config files. The IDE-and-lint project declaration lives in `tsconfig.json` (broad include + `allowJs`).
 */
{
  "compilerOptions": {

    "outDir": "dist",
    "rootDir": "src"
  },

  "exclude": [

    "dist",
    "node_modules",
    "src/**/*.fixtures.cts", "src/**/*.fixtures.mts", "src/**/*.fixtures.ts",
    "src/**/*.helpers.cts", "src/**/*.helpers.mts", "src/**/*.helpers.ts",
    "src/**/*.test.cts", "src/**/*.test.mts", "src/**/*.test.ts"
  ],
  "extends": "./build/tsconfig.json",
  "include": [ "src" ]
}
